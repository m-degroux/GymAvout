<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="4dp">

    <!-- Message de l'autre (gauche) -->
    <RelativeLayout
        android:id="@+id/layoutPartnerMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgMessagePartner"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentBottom="true"
            android:src="@drawable/logo_gymavout"
            app:shapeAppearanceOverlay="@style/CircleImage" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_toEndOf="@id/imgMessagePartner"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/txtPartnerMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Message"
                android:textColor="@color/white"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtPartnerTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="14:20"
                android:textColor="#9CA3AF"
                android:textSize="10sp" />
        </LinearLayout>
    </RelativeLayout>

    <!-- Mon message (droite) -->
    <LinearLayout
        android:id="@+id/layoutMyMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_stat_teal"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/txtMyMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mon message"
            android:textColor="@color/white"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txtMyTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="4dp"
            android:text="14:22"
            android:textColor="#9CA3AF"
            android:textSize="10sp" />
    </LinearLayout>

</LinearLayout>
