<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gym_dark_bg">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/gym_green_primary"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Créer une activité"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout style="@style/FormContainerStyle">
                <TextView style="@style/LabelStyle" android:text="Titre de l'activité *" />
                <EditText
                    android:id="@+id/etActivityTitle"
                    style="@style/InputStyle"
                    android:hint="Ex: Match de foot amical"
                    android:inputType="textPersonName" />
            </LinearLayout>

            <LinearLayout style="@style/FormContainerStyle">
                <TextView style="@style/LabelStyle" android:text="Sport *" />
                <Spinner
                    android:id="@+id/sportSpinner"
                    style="@style/InputStyle"
                    android:entries="@array/sport_array"
                    android:spinnerMode="dropdown" />
            </LinearLayout>

            <LinearLayout style="@style/FormContainerStyle">
                <TextView style="@style/LabelStyle" android:text="Description *" />
                <EditText
                    android:id="@+id/etDescription"
                    style="@style/InputStyle"
                    android:layout_height="wrap_content"
                    android:minHeight="80dp"
                    android:gravity="top"
                    android:hint="Décrivez votre activité..."
                    android:lines="4"
                    android:paddingTop="12dp" />
            </LinearLayout>

            <LinearLayout style="@style/FormContainerStyle">
                <TextView style="@style/LabelStyle" android:text="Lieu *" />
                <EditText
                    android:id="@+id/etLocation"
                    style="@style/InputStyle"
                    android:hint="Ex: Stade Municipal, Paris 15ème" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <LinearLayout style="@style/FormContainerStyle" android:layout_width="0dp" android:layout_weight="1" android:layout_marginEnd="8dp">
                    <TextView style="@style/LabelStyle" android:text="Date *" />
                    <EditText
                        android:id="@+id/etDate"
                        style="@style/InputStyle"
                        android:hint="jj / mm / aaaa"
                        android:focusable="false"
                        android:clickable="true"
                        android:cursorVisible="false" />
                </LinearLayout>

                <LinearLayout style="@style/FormContainerStyle" android:layout_width="0dp" android:layout_weight="1" android:layout_marginStart="8dp">
                    <TextView style="@style/LabelStyle" android:text="Heure *" />
                    <EditText
                        android:id="@+id/etTime"
                        style="@style/InputStyle"
                        android:hint="-- : --"
                        android:focusable="false"
                        android:clickable="true"
                        android:cursorVisible="false" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout style="@style/FormContainerStyle">
                <TextView style="@style/LabelStyle" android:text="Nombre max participants *" />
                <EditText
                    android:id="@+id/etMaxParticipants"
                    style="@style/InputStyle"
                    android:hint="Ex: 10"
                    android:inputType="number" />
            </LinearLayout>

            <LinearLayout style="@style/FormContainerStyle">
                <TextView style="@style/LabelStyle" android:text="Niveau requis *" />
                <Spinner
                    android:id="@+id/spinnerLevels"
                    style="@style/InputStyle"
                    android:entries="@array/levels_array"
                    android:spinnerMode="dropdown" />
            </LinearLayout>

            <Button
                android:id="@+id/btnPublish"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="@color/gym_green_primary"
                android:text="Publier l'activité"
                android:textAllCaps="false"
                android:textColor="@color/white"
                app:cornerRadius="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="32dp"
                android:text="* Champs obligatoires"
                android:textColor="@color/text_gray"
                android:textSize="12sp" />
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>